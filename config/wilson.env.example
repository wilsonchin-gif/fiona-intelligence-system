# Copy this file to config/wilson.env and fill in your Telegram targets.

# Telegram BotFather token.
TELEGRAM_BOT_TOKEN=123456789:replace_with_your_bot_token

# You can use @channel_username or numeric IDs such as -1001234567890.
TELEGRAM_CHANNEL_ID=@your_channel_username
TELEGRAM_GROUP_ID=-1001234567890

# Optional: comma-separated override. If set, the bot sends to every ID here.
# TELEGRAM_CHAT_IDS=@your_channel_username,-1001234567890

# Local schedule / runtime controls.
WILSON_INTERVAL_MINUTES=240
WILSON_TIMEZONE=Asia/Manila
WILSON_OUTPUT_DIR="$HOME/Desktop/Wilsons Market News"
# Internal test default: generate files only. Set to 1 when Telegram targets are ready.
WILSON_SEND=0
